# ── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/fundability?sslmode=require

# ── AI Provider ──────────────────────────────────────────────────────────────
# Set to "openai" to switch to OpenAI GPT (default: mistral)
AI_PROVIDER=mistral
MISTRAL_API_KEY=your-mistral-api-key
OPENAI_API_KEY=sk-...                    # only needed if AI_PROVIDER=openai

# ── Brevo SMTP (email) ───────────────────────────────────────────────────────
# Get these from Brevo → SMTP & API → SMTP
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your@email.com           # your Brevo login email
BREVO_SMTP_PASS=your-brevo-smtp-key      # the SMTP key from Brevo dashboard
BREVO_FROM_EMAIL=reports@devmantra.com
BREVO_FROM_NAME=Dev Mantra
BREVO_REPLY_TO=advisory@devmantra.com

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BOOKING_URL=https://calendly.com/devmantra
NEXT_PUBLIC_SITE_URL=https://startups.devmantra.com

# ── Admin Dashboard API ───────────────────────────────────────────────────────
ADMIN_API_USERNAME=admin
ADMIN_API_PASSWORD=your-strong-password-here
